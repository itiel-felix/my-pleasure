# LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# Optional
GROQ_API_KEY=

# Microphone (run: venv/bin/python list_devices.py)
INPUT_DEVICE_INDEX=

# Hey Jarvis sensitivity (0–1). Lower = more sensitive, more false triggers.
WAKE_WORD_THRESHOLD=0.6

# Vosk STT sensitivity. Lower RMS = picks up quieter speech.
STT_RMS_THRESHOLD=500
STT_MAX_SILENCE_SECONDS=1.5
STT_MAX_DURATION_SEC=10
